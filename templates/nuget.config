<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- BieberWorks-Pakete liegen in GitHub Packages der Org (privat, token-only). -->
    <add key="bieberworks" value="https://nuget.pkg.github.com/BieberWorks/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <!--
      Zugangsdaten kommen aus Umgebungsvariablen - NIEMALS Token einchecken.
      Vor dem ersten Restore setzen (PAT mit Scope read:packages):
        BIEBERWORKS_NUGET_USER  = dein GitHub-Benutzername
        BIEBERWORKS_NUGET_TOKEN = dein PAT (read:packages)
    -->
    <bieberworks>
      <add key="Username" value="%BIEBERWORKS_NUGET_USER%" />
      <add key="ClearTextPassword" value="%BIEBERWORKS_NUGET_TOKEN%" />
    </bieberworks>
  </packageSourceCredentials>
</configuration>
