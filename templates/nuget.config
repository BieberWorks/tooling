<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      Dev-Linking: SDK-weiter lokaler Feed im Container-Root (kein PAT, kein Git-Repo).
      Ermoeglicht PAT-loses lokales Bauen gegen die noch nicht released Pakete.
    -->
    <add key="bieberworks-local" value="..\local-nuget-feed" />
  </packageSources>
  <!--
    KEINE GitHub-Packages-Quelle hier eintragen: Die CI-Workflows
    (BieberWorks/tooling/.github/workflows/dotnet-ci.yml + nuget-release.yml)
    entfernen 'bieberworks-local'/'bieberworks' und fuegen die GitHub-Quelle
    dynamisch via PACKAGES_TOKEN/GITHUB_TOKEN hinzu. Eine statische
    GitHub-Quelle mit %BIEBERWORKS_NUGET_TOKEN% wuerde PAT-loses lokales
    Bauen mit 401 brechen.
  -->
</configuration>
