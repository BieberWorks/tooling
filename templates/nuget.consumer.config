<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      BieberWorks SDK-Pakete werden aus GitHub Packages der Org BieberWorks geliefert.
      Voraussetzung: Ein GitHub PAT mit read:packages-Scope.
      Umgebungsvariable setzen: $env:BIEBERWORKS_NUGET_TOKEN = 'ghp_...'
      Oder in der Windows Credential Manager / User-Level nuget.config eintragen.
    -->
    <add key="bieberworks" value="https://nuget.pkg.github.com/BieberWorks/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <bieberworks>
      <!--
        Username: dein GitHub-Benutzername (kein Platzhalter, da sourceName-Ersetzung
        auf nuget.config-Credentials nicht zuverlaessig ist).
        ClearTextPassword: PAT mit read:packages, als Umgebungsvariable BIEBERWORKS_NUGET_TOKEN.
      -->
      <add key="Username" value="GITHUB_USERNAME_PLACEHOLDER" />
      <add key="ClearTextPassword" value="%BIEBERWORKS_NUGET_TOKEN%" />
    </bieberworks>
  </packageSourceCredentials>
</configuration>
